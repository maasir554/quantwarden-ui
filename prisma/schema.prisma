generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id       String   @id @default(uuid())
  name     String
  domains  String[]
  users    User[]
}

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  password String
  role     String
  orgId    String
  org      Organization @relation(fields: [orgId], references: [id])
}